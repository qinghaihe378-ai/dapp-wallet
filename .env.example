# Birdeye API Key (可选，用于行情备用数据源)
# 在 https://bds.birdeye.so 注册获取
# VITE_BIRDEYE_API_KEY=your_api_key_here

# Uniswap Trading API Key (可选，用于 Base/Mainnet 自动匹配 V2/V3/V4 最优路由)
# 在 https://developers.uniswap.org/dashboard 注册获取
# VITE_UNISWAP_API_KEY=your_api_key_here

# Uniswap API 代理 (可选，当直连失败如 Failed to fetch 时，可自建代理并配置)
# 代理需将请求转发到 https://trade-api.gateway.uniswap.org/v1
# VITE_UNISWAP_API_PROXY=https://your-proxy.com/uniswap

# 已部署站点根 URL（生产默认可见 .env.production；本地可覆盖；无尾斜杠）
# VITE_API_BASE=https://ipfs-social-1a7l.vercel.app

# ---------- 后台 /admin（仅服务端，勿加 VITE_ 前缀）----------
# 登录密码；部署到 Vercel 等必须在「项目环境变量」里配置，否则线上仍是旧密码
# ADMIN_PASSWORD=your_password
# 会话签名密钥，随机长串即可（建议 ≥32 字符）
# ADMIN_SECRET=your_random_secret_at_least_32_chars
# 行情 API 等用到的 Redis（服务端）
# REDIS_URL=redis://...
